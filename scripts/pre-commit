#!/bin/sh
# Pre-commit hook: runs cargo fmt and cargo clippy before allowing commit.
# Both must pass or the commit is rejected.
#
# Install: make setup-hooks
# Or manually: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

echo "[pre-commit] Running cargo fmt --all -- --check..."
cargo fmt --all -- --check
if [ $? -ne 0 ]; then
    echo ""
    echo "[pre-commit] FAILED: Code is not formatted. Run 'cargo fmt --all' and re-commit."
    exit 1
fi

echo "[pre-commit] Running cargo clippy --workspace --all-targets -- -D warnings..."
cargo clippy --workspace --all-targets -- -D warnings
if [ $? -ne 0 ]; then
    echo ""
    echo "[pre-commit] FAILED: Clippy found warnings. Fix them and re-commit."
    exit 1
fi

echo "[pre-commit] All checks passed."
