# Production environment — tuned for real traffic with proper rate limits
# Usage: make up-prod  or  docker compose --env-file env/production.env up -d

# Database
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=5
DB_ACQUIRE_TIMEOUT_SECS=5

# Redis
REDIS_POOL_SIZE=15

# Rate limiting (per-user/per-IP)
RATE_LIMIT_READ_PER_MINUTE=1000
RATE_LIMIT_WRITE_PER_MINUTE=30

# Server
SERVER_CONCURRENCY_LIMIT=200

# Cache TTLs
CACHE_TTL_LIKE_COUNTS_SECS=300
CACHE_TTL_CONTENT_VALIDATION_SECS=3600
CACHE_TTL_USER_STATUS_SECS=60
CACHE_TTL_LIKE_STATUS_SECS=300
CACHE_TTL_USER_LIKES_SECS=60
CACHE_TTL_LEADERBOARD_FILTERED_SECS=60

# L1 in-process cache (moka)
LOCAL_CACHE_TTL_MS=200
LOCAL_CACHE_MAX_CAPACITY=10000

# Circuit breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECS=30
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3

# Logging
LOG_LEVEL=info
