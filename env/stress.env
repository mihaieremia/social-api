# Stress test environment — uncapped limits, oversized pools for max throughput
# Usage: make up-stress  or  docker compose --env-file env/stress.env up -d

# Database (5x production — saturate connection pool)
DB_MAX_CONNECTIONS=100
DB_MIN_CONNECTIONS=20
DB_ACQUIRE_TIMEOUT_SECS=10

# Redis (larger pool for concurrent stress load)
REDIS_POOL_SIZE=50

# Rate limiting (effectively disabled for stress testing)
RATE_LIMIT_READ_PER_MINUTE=1000000
RATE_LIMIT_WRITE_PER_MINUTE=100000

# Server (uncapped concurrency for stress testing)
SERVER_CONCURRENCY_LIMIT=10000

# Cache TTLs (longer token cache to reduce mock-services load)
CACHE_TTL_LIKE_COUNTS_SECS=300
CACHE_TTL_CONTENT_VALIDATION_SECS=3600
CACHE_TTL_USER_STATUS_SECS=300
CACHE_TTL_LIKE_STATUS_SECS=300
CACHE_TTL_USER_LIKES_SECS=120
CACHE_TTL_LEADERBOARD_FILTERED_SECS=120

# L1 in-process cache (moka)
LOCAL_CACHE_TTL_MS=200
LOCAL_CACHE_MAX_CAPACITY=10000

# Circuit breaker (relaxed — don't trip during stress)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=100
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_SECS=10
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=1

# Logging
LOG_LEVEL=info
